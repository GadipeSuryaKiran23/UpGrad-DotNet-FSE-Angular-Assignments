@model List<Product>
<h1 class="display-5">Product List:</h1>

<a class="btn btn-primary" asp-action="AddProducts">Add Products</a>
<hr/>


<table border="1" cellpadding="10" cellspacing="0" class="table">
    <thead>
        <tr>
            <th>Product Name</th>
            <th>Price</th>
            <th>Quantity</th>
        </tr>
    </thead>

    <tbody>
        @foreach(Product item in Model)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.Price</td>
                <td>@item.Quantity</td>
            </tr>
        }
    </tbody>
</table>