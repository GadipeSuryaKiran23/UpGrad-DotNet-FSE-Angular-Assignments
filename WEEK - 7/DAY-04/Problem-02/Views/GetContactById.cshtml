@model DataAccessLayer.Models.ContactInfo

@{
    ViewData["Title"] = "Contact Details";
}

<h2>Contact Details</h2>

<div class="card p-3">
    <p><strong>Contact ID:</strong> @Model.ContactId</p>
    <p><strong>First Name:</strong> @Model.FirstName</p>
    <p><strong>Last Name:</strong> @Model.LastName</p>
    <p><strong>Email:</strong> @Model.EmailId</p>
    <p><strong>Mobile No:</strong> @Model.MobileNo</p>
    <p><strong>Designation:</strong> @Model.Designation</p>
    <p><strong>Company:</strong> @Model.Company?.CompanyName</p>
    <p><strong>Department:</strong> @Model.Department?.DepartmentName</p>
</div>

<br />
<a asp-action="ShowContacts" class="btn btn-secondary">Back to List</a>