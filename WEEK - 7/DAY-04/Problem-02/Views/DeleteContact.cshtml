@model DataAccessLayer.Models.ContactInfo

@{
    ViewData["Title"] = "Delete Contact";
}

<h2>Delete Contact</h2>

<div class="alert alert-danger">
    <h4>Are you sure you want to delete this contact?</h4>
</div>

<div class="card p-3">
    <p><strong>Contact ID:</strong> @Model.ContactId</p>
    <p><strong>Name:</strong> @Model.FirstName @Model.LastName</p>
    <p><strong>Email:</strong> @Model.EmailId</p>
    <p><strong>Mobile:</strong> @Model.MobileNo</p>
    <p><strong>Designation:</strong> @Model.Designation</p>
    <p><strong>Company:</strong> @Model.Company?.CompanyName</p>
    <p><strong>Department:</strong> @Model.Department?.DepartmentName</p>
</div>

<br />

<form asp-action="DeleteConfirmed" asp-route-id="@Model.ContactId" method="post">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="ShowContacts" class="btn btn-secondary">Cancel</a>
</form>