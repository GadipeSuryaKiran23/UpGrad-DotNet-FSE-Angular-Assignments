@model ContactInfo

@{
    ViewData["Title"] = "Delete Contact";
}

<h2>Delete Contact</h2>

<h4>Are you sure you want to delete this contact?</h4>

<dl class="row">
    <dt class="col-sm-3">First Name</dt>
    <dd class="col-sm-9">@Model.FirstName</dd>

    <dt class="col-sm-3">Last Name</dt>
    <dd class="col-sm-9">@Model.LastName</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.EmailId</dd>

    <dt class="col-sm-3">Mobile</dt>
    <dd class="col-sm-9">@Model.MobileNo</dd>

    <dt class="col-sm-3">Designation</dt>
    <dd class="col-sm-9">@Model.Designation</dd>

    <dt class="col-sm-3">Company</dt>
    <dd class="col-sm-9">@Model.CompanyName</dd>

    <dt class="col-sm-3">Department</dt>
    <dd class="col-sm-9">@Model.DepartmentName</dd>
</dl>

<form asp-action="DeleteContact" asp-route-id="@Model.ContactId" method="post">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="ShowContacts" class="btn btn-secondary">Cancel</a>
</form>